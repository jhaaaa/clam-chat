# Pinata IPFS — required for remote attachments (files > 1MB) to work cross-device.
# Get these from https://app.pinata.cloud/
#
# Without these, large file attachments will only work locally in your browser.
# Small files (< 1MB) are sent inline and always work.
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=

# WalletConnect — optional, needed for "Connect wallet" sign-in.
# Get a project ID from https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Ethereum RPC — optional, used for ENS name resolution.
# Defaults to public RPCs (llamarpc, ankr, cloudflare, publicnode).
VITE_ETH_RPC_URL=
